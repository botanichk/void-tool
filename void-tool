# ── self-install ─────────────────────────────────────────

def cmd_self_install(args):
    """Install void-tool from repo clone to system (~/.local/bin)."""
    repo_dir = Path(args.source).resolve()
    scripts_src = repo_dir / "scripts"
    krs_src = repo_dir / "krs"

    if not (repo_dir / "void-tool").exists():
        print(rd(f"✗ void-tool not found in {repo_dir}"))
        return 1

    print(f"  {bl('⟳')} Installing void-tool from {repo_dir}...")

    # 1. copy main script
    bin_dir = Path.home() / ".local" / "bin"
    bin_dir.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(repo_dir / "void-tool"), str(bin_dir / "void-tool"))
    (bin_dir / "void-tool").chmod(0o755)
    print(f"  ✓ {gr('void-tool')} → {bin_dir}")

    # 2. copy scripts
    if scripts_src.exists():
        user_scripts = Path.home() / "scripts"
        user_scripts.mkdir(parents=True, exist_ok=True)
        for f in scripts_src.glob("*.sh"):
            shutil.copy2(str(f), str(user_scripts / f.name))
            (user_scripts / f.name).chmod(0o755)
            print(f"  ✓ {f.name} → {user_scripts}")

    # 3. build and install krs
    krs_bin = bin_dir / "krs"
    if krs_src.exists():
        cargo = shutil.which("cargo")
        if cargo:
            print(f"  {bl('⟳')} Building krs (Rust)...")
            r = subprocess.run(
                [cargo, "build", "--release"],
                cwd=str(krs_src), capture_output=True, text=True, timeout=180)
            if r.returncode == 0:
                built = krs_src / "target" / "release" / "krs"
                if built.exists():
                    shutil.copy2(str(built), str(krs_bin))
                    krs_bin.chmod(0o755)
                    print(f"  ✓ krs (Rust) → {krs_bin}")
            else:
                print(f"  {yl('⚠')} krs build failed — install cargo and run manually")
                print(f"     cd {krs_src} && cargo build --release && cp target/release/krs ~/.local/bin/")
        else:
            print(f"  {yl('⚠')} cargo not found — install rustup first, then build krs manually")
            print(f"     cd {krs_src} && cargo build --release && cp target/release/krs ~/.local/bin/")

    # 4. create default config
    config_file = CONFIG_DIR / "config.toml"
    if not config_file.exists():
        config_file.parent.mkdir(parents=True, exist_ok=True)
        config_file.write_text(DEFAULT_CONFIG)
        print(f"  ✓ config → {config_file}")
    else:
        print(f"  ✓ config exists → {config_file}")

    # 5. install completions
    cmd_completions(argparse.Namespace(shell="install"))

    print(f"\n  {gr('✓')} void-tool installed. Reload shell or run:")
    print(f"     exec $SHELL")
    print(f"     void-tool --version")
    return 0


# ── menu ────────────────────────────────────────────────

def cmd_menu(args=None):
    """Interactive menu using fzf (if available) or simple numbered prompt."""
    items = [
        ("─── update ─────────────────────", None),
        ("Update — check for updates",     lambda: cmd_update_check(None)),
        ("Update — all modules",           lambda: cmd_update_run(argparse.Namespace(modules=[]))),
        ("Update — Zen Browser",           lambda: cmd_update_run(argparse.Namespace(modules=["zen"]))),
        ("Update — PortProtonQt",          lambda: cmd_update_run(argparse.Namespace(modules=["ppqt"]))),
        ("Update — show status",           lambda: cmd_update_status(None)),
        ("─── install ────────────────────", None),
        ("Install — Zen Browser",          lambda: cmd_install(argparse.Namespace(packages=["zen"]))),
        ("Install — PortProtonQt",         lambda: cmd_install(argparse.Namespace(packages=["ppqt"]))),
        ("Install — NVIDIA Drivers",       lambda: cmd_install(argparse.Namespace(packages=["nvidia"]))),
        ("Install — PipeWire (Void)",      lambda: cmd_install(argparse.Namespace(packages=["pipewire"]))),
        ("Install — NVIDIA 32-bit libs",   lambda: cmd_install(argparse.Namespace(packages=["nvidia-32bit"]))),
        ("─── fix ────────────────────────", None),
        ("Fix — audio health check",       lambda: cmd_fix_health(None)),
        ("─── clean ──────────────────────", None),
        ("Clean — xbps-src builds",        lambda: cmd_clean(argparse.Namespace(targets=["builds"]))),
        ("Clean — system cache",           lambda: cmd_clean(argparse.Namespace(targets=["cache"]))),
    ]

    fzf = subprocess.run(["which", "fzf"], capture_output=True, text=True).returncode == 0

    while True:
        if fzf:
            labels = "\n".join(f"{l}" for l, a in items if a is not None)
            sel = subprocess.run(
                ["fzf", "--prompt=void-tool > ", "--height=~50%"],
                input=labels, capture_output=True, text=True
            )
            if sel.returncode != 0:
                break
            choice = sel.stdout.strip()
            for label, action in items:
                if action is not None and label == choice:
                    action()
                    break
        else:
            print(f"\n  {bl('void-tool')} {yl(TAGLINE)}")
            print(f"  {gr('─' * 40)}")
            idx = 0
            for label, action in items:
                if action is None:
                    print(f"  {bl(label)}")
                else:
                    idx += 1
                    print(f"  {yl(str(idx)):>2}) {label}")
            print(f"  0) {rd('Quit')}")
            try:
                c = input(f"\n  {yl('Choice')} [0-{idx}]: ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                break
            if c == "0" or c == "":
                break
            try:
                n = int(c)
                real_idx = 0
                for label, action in items:
                    if action is not None:
                        real_idx += 1
                        if real_idx == n:
                            action()
                            break
            except ValueError:
                print(f"  {rd('Enter a number')}")

        input(f"\n  {yl('Press Enter to continue')}...")
    return 0


# ── arg parser ──────────────────────────────────────────

def make_parser():
    p = argparse.ArgumentParser(
        prog=TOOL_NAME,
        description=f"void-tool — {TAGLINE}")
    p.add_argument("--version", action="version", version=f"%(prog)s {TAGLINE}")

    sub = p.add_subparsers(dest="command")

    # install
    pi = sub.add_parser("install", help="Install a package (zen, ppqt, nvidia, nvidia-32bit, pipewire)")
    pi.add_argument("packages", nargs="+", choices=["zen", "ppqt", "nvidia", "pipewire"],
                    help="Package(s) to install — zen, ppqt, nvidia, nvidia-32bit, pipewire")

    # update
    pu = sub.add_parser("update", help="Update modules or check status")
    pu.add_argument("targets", nargs="*",
                    help="check | status | <module>... (default: update all)")

    # fix
    pf = sub.add_parser("fix", help="Diagnose and fix system issues")
    pf.add_argument("target", choices=["health"],
                    help="What to fix")

    # clean
    pc = sub.add_parser("clean", help="Clean build artifacts")
    pc.add_argument("targets", nargs="+", choices=["builds", "cache", "prefixes"],
                    help="What to clean")

    sub.add_parser("trigger", help="For Hyprland: check interval, then check+health")

    pcomp = sub.add_parser("completions", help="Generate shell completion scripts")
    pcomp.add_argument("shell", choices=["bash", "zsh", "install"],
                       help="Shell to generate completions for (install = auto-detect)")

    sub.add_parser("menu", help="Interactive TUI (arrow keys)")
    psi = sub.add_parser("self-install", help="Install void-tool from repo clone to system")
    psi.add_argument("--source", default=".",
                      help="Path to repo root (default: current dir)")
    sub.add_parser("_list_modules", help=argparse.SUPPRESS)

    return p


# ── dispatch ────────────────────────────────────────────

def main():
    parser = make_parser()
    args = parser.parse_args()

    if not args.command:
        return cmd_menu()

    dispatch = {
        "install":       cmd_install,
        "fix":           cmd_fix_health,
        "clean":         cmd_clean,
        "trigger":       cmd_trigger,
        "completions":   cmd_completions,
        "menu":          cmd_menu,
        "self-install":  cmd_self_install,
        "_list_modules": cmd_list_modules,
    }

    # 'update' is special — sub-dispatch
    if args.command == "update":
        if not args.targets:
            return cmd_update_run(argparse.Namespace(modules=[]))
        first = args.targets[0]
        if first == "check":
            return cmd_update_check(None)
        elif first == "status":
            return cmd_update_status(None)
        else:
            return cmd_update_run(argparse.Namespace(modules=args.targets))

    if args.command in dispatch:
        return dispatch[args.command](args)

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
