BASH_COMP_DIR = Path.home() / ".local" / "share" / "bash-completion" / "completions"
ZSH_COMP_DIR = Path.home() / ".local" / "share" / "zsh" / "site-functions"


def cmd_completions(args):
    name = "void-tool"
    if args.shell == "bash":
        print(BASH_COMPLETION, end="")
    elif args.shell == "zsh":
        print(ZSH_COMPLETION, end="")
    elif args.shell == "install":
        shell = Path(os.environ.get("SHELL", "/bin/bash")).name
        if shell == "zsh":
            ZSH_COMP_DIR.mkdir(parents=True, exist_ok=True)
            (ZSH_COMP_DIR / f"_{name}").write_text(ZSH_COMPLETION)
            print(f"Zsh completion installed: {ZSH_COMP_DIR / f'_{name}'}")
            print("Reload with: exec zsh")
        elif shell == "bash":
            BASH_COMP_DIR.mkdir(parents=True, exist_ok=True)
            (BASH_COMP_DIR / name).write_text(BASH_COMPLETION)
            print(f"Bash completion installed: {BASH_COMP_DIR / name}")
            print("Reload with: exec bash")
        else:
            print(f"Unknown shell: {shell}. Use '{name} completions bash' or '{name} completions zsh'")
            return 1


